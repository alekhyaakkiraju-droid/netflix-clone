# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/netflix_db

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Payment
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...

# Logging
LOG_LEVEL=info
