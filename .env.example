# ── Frontend ──────────────────────────────────────────────────────────────────
# Points to the Node.js API base URL. In development with docker compose,
# Vite proxies /api → http://server:3001, so VITE_API_URL can be /api/v1
VITE_API_URL=http://localhost:3001/api/v1

# ── Docker Compose ────────────────────────────────────────────────────────────
# Used by docker-compose.yml for the postgres service
POSTGRES_USER=netflixforged
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=netflixforged
